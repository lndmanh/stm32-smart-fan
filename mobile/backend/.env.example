PORT=3000
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=fan
CORS_ORIGIN=*

# serial = nối STM32 qua COM | simulator = mô phỏng (không cần mạch)
DEVICE_MODE=simulator
# Khi dùng serial: đặt đúng cổng (Device Manager / GET /api/device/ports), hoặc để trống để tự chọn
# SERIAL_PORT=COM3
SERIAL_BAUD=115200
